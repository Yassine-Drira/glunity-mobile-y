{
  "expo": {
    "name": "Glunity",
    "slug": "glunity-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#8BC34A"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-image",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "ios": {
            "associatedDomains": ["applinks:myapp.com", "applinks:www.myapp.com"]
          }
        }
      ]
    ],
    "android": {
      "package": "com.islemhammami.glunitymobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8BC34A"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "myapp.com",
              "pathPrefix": "/reel/"
            },
            {
              "scheme": "https",
              "host": "www.myapp.com",
              "pathPrefix": "/reel/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [{ "scheme": "glunity" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.islemhammami.glunitymobile",
      "associatedDomains": ["applinks:myapp.com", "applinks:www.myapp.com"]
    },
    "scheme": "glunity"
  }
}

